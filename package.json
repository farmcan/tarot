{
  "name": "tarot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "pages:dev": "npm run build && wrangler pages dev v1 --compatibility-date=2026-06-29 --port 8788",
    "deploy": "npm run verify:launch && wrangler pages deploy v1 --project-name tarot",
    "secret:llm": "wrangler pages secret put LLM_API_KEY --project-name tarot",
    "counter:db:create": "wrangler d1 create miaotarot-stats --location apac --binding MIAOTAROT_DB --update-config",
    "counter:db:migrate": "wrangler d1 migrations apply miaotarot-stats --remote",
    "counter:db:migrate:local": "wrangler d1 migrations apply miaotarot-stats --local",
    "prepare:meme-bases": "node scripts/prepare-miao-meme-bases.mjs",
    "fetch:famous-memes": "node scripts/fetch-miao-famous-memes.mjs",
    "optimize:assets": "node scripts/optimize-miao-assets.mjs",
    "optimize:doodle-pack": "node scripts/optimize-miao-doodle-pack.mjs",
    "generate:zh-hans": "node scripts/generate-zh-hans-map.mjs",
    "sync:standard-assets": "node scripts/sync-standard-tarot-assets.mjs",
    "review:art-sheets": "node scripts/build-miao-review-sheets.mjs",
    "export:art-prompts": "node scripts/export-miao-art-prompts.mjs",
    "export:minor-art-prompts": "tsx scripts/export-miao-minor-art-prompts.ts",
    "export:pack-html": "tsx scripts/export-miao-content-pack-html.ts",
    "export:content": "npm run export:art-prompts && npm run export:minor-art-prompts && npm run export:pack-html",
    "verify:content": "node scripts/verify-content-launch.mjs",
    "verify:pages": "node scripts/verify-pages-dev.mjs",
    "verify:launch": "npm run export:content && npm run typecheck && npm run build && npm run verify:content && npm run verify:pages && npm run test:counter && npm run test:events && npm run test:interaction && npm run test:minor && npm run test:packs && npm run test:state && npm run test:e2e",
    "smoke:llm": "node scripts/smoke-llm-proxy.mjs",
    "smoke:llm:local": "npm run build && node scripts/smoke-llm-local.mjs",
    "smoke:production": "node scripts/smoke-production.mjs",
    "test:counter": "node scripts/test-site-counter.mjs",
    "test:events": "node scripts/test-product-events.mjs",
    "test:interaction": "tsx scripts/test-interactive-draw.ts",
    "test:minor": "tsx scripts/test-minor-arcana.ts",
    "test:packs": "tsx scripts/test-content-packs.ts",
    "test:state": "tsx scripts/test-reading-state.ts",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cometpisces/tarot-kit": "^0.2.0",
    "@cometpisces/tarot-kit-images": "^0.2.0",
    "@mantine/core": "^9.3.2",
    "@mantine/hooks": "^9.3.2",
    "@vitejs/plugin-react": "^6.0.2",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.21.0",
    "motion": "^12.42.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "opencc-js": "^1.0.5",
    "pngjs": "^5.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.105.0"
  }
}
